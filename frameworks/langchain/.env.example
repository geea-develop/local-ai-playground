# Example environment for MLX agent examples
# (`mlx_lm_langchain_agent_simple_example.py` and `mlx_lm_langchain_agent_example.py`)
#
# MODELS_DIR_PATH points to the directory containing your model folders.
# MODEL_DIR_PATH is the model folder name/path relative to MODELS_DIR_PATH.
MODELS_DIR_PATH=./models
MODEL_DIR_PATH=lmstudio-community/Qwen3-4B-Instruct-2507-MLX-4bit
# Cap on generated tokens (backend clamps API max_tokens to this). Default in code is 2048.
# MAX_GENERATION_TOKENS=4096
LOG_LEVEL=INFO

# OLLAMA_LLM_MODEL=
# OLLAMA_EMBED_MODEL=
# OLLAMA_API_BASE=
# MODEL_FILE_PATH=
# USE_LOCAL_FILE=