# Cognee Configuration

# LLM Configuration (Local Ollama)
LLM_PROVIDER="ollama"
LLM_MODEL="mistral:v0.3"  # or deepseek-r1:32b, etc.
LLM_ENDPOINT="http://localhost:11434/v1"
LLM_API_KEY="ollama"
# Forces the model to use JSON mode, reducing wrapping errors
LLM_INSTRUCTOR_MODE="json_mode"

# Embedding Configuration
EMBEDDING_PROVIDER="ollama"
EMBEDDING_MODEL="nomic-embed-text"
EMBEDDING_ENDPOINT="http://localhost:11434"
EMBEDDING_DIMENSIONS=768 # Match your embedding model's dimensions
HUGGINGFACE_TOKENIZER="nomic-ai/nomic-embed-text-v1"

# Optional: Framework for structured output
STRUCTURED_OUTPUT_FRAMEWORK="instructor"

# Logging
LOG_LEVEL=INFO

COGNEE_SKIP_CONNECTION_TEST=true